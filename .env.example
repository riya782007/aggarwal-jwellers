# ============================================================================
#  Aggarwal Jewellers — environment variables (set these on Vercel)
#  Copy to .env.local for local dev. Grouped by REQUIRED → RECOMMENDED → OPTIONAL.
#  NEXT_PUBLIC_* are exposed to the browser; everything else is server-only.
# ============================================================================

# ---------------------------------------------------------------------------
#  1) REQUIRED — the app will not run without these
# ---------------------------------------------------------------------------
# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Owner console auth (SECURITY-CRITICAL — set BOTH). The admin session cookie is a
# SHA-256 derived from these, so the session cannot be forged from source.
OWNER_PASSCODE=            # the passcode the owner types to sign in — change from any demo value
ADMIN_SESSION_TOKEN=       # any long random string, e.g.  openssl rand -hex 32
OWNER_OTP=                 # numeric OTP guarding sensitive actions (e.g. bulk deletes)

# Public site basics
NEXT_PUBLIC_SITE_URL=https://aggarwaljeweller.in
NEXT_PUBLIC_STORE_NAME=Aggarwal Jewellers

# ---------------------------------------------------------------------------
#  2) RECOMMENDED — needed for the full live experience
# ---------------------------------------------------------------------------
# UPI scan-to-pay QR (wholesale checkout + GST invoices). VERIFY by test-scanning.
BUSINESS_UPI_VPA=AGGARWALJEWELLERS579@icici

# Retail online payments (Razorpay). Leave blank to run COD-only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# WhatsApp order notifications — pick ONE provider.
#   provider = "cloud" (Meta WhatsApp Cloud API)  OR  "twilio"
WHATSAPP_PROVIDER=
# Meta Cloud API:
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ORDER_TEMPLATE=
WHATSAPP_TEMPLATE_LANG=en
# Twilio (alternative):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Notification recipients (digits only). BUSINESS_WHATSAPP also powers every "message us" link.
BUSINESS_WHATSAPP=911140047222
OWNER_WHATSAPP_NUMBER=
STAFF_WHATSAPP_NUMBER=

# AI — DIVA assistant, product descriptions, and AI product photos.
# Any one provider enables it; all three give graceful fallback.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=
GEMINI_IMAGE_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_IMAGE_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
AI_BUDGET_PAISE=500000     # monthly AI spend cap in paise (₹5,000 default)

# Google Analytics 4 (storefront traffic)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GA4_PROPERTY_ID=

# ---------------------------------------------------------------------------
#  3) OPTIONAL — sensible defaults exist in code; override only if needed
# ---------------------------------------------------------------------------
# Invoice bank block — defaults are already set in lib/business.ts; these override.
BLYTHE_BANK_NAME=
BLYTHE_BANK_ACCOUNT=
BLYTHE_BANK_IFSC=
BLYTHE_BANK_BRANCH=

COD_MAX_RUPEES=5000        # Cash-on-Delivery ceiling for retail orders
ALLOW_SEED=                # set to "1" only when running demo seed scripts; keep blank in prod

# NOTE: Do NOT set TZ on Vercel (it's a reserved name and will be rejected).
# The server timezone is forced to Asia/Kolkata (IST) in code via instrumentation.ts.
