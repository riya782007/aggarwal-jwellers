# ---- Supabase (required for app; NOT required for unit tests) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Demo safety ----
# The Phase-1 demo path makes NO live AI/3rd-party calls. Keys below are optional and
# only used by offline scripts (scripts/generate-content.ts) or later phases.

# ---- Optional: AI providers (offline content pre-generation only) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_BUDGET_PAISE=500000

# =====================================================================
#  PAYMENTS — Razorpay (online checkout). See INTEGRATIONS-SETUP.md.
#  Leave blank to keep Cash-on-Delivery only; online pay appears once these are set.
# =====================================================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# The SAME key id, exposed to the browser checkout (must start with NEXT_PUBLIC_):
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# =====================================================================
#  WHATSAPP — order confirmations & owner alerts. See INTEGRATIONS-SETUP.md.
#  Provider: "meta" (default, official Cloud API) or "twilio".
#  Leave blank to disable automated WhatsApp (wa.me click-to-chat still works).
# =====================================================================
WHATSAPP_PROVIDER=meta
OWNER_WHATSAPP_NUMBER=           # where new-order alerts go, e.g. 919873151767

# --- Meta WhatsApp Cloud API (recommended) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_ORDER_TEMPLATE=         # approved template name (optional; plain text used if blank)
WHATSAPP_TEMPLATE_LANG=en

# --- Twilio WhatsApp (alternative; set WHATSAPP_PROVIDER=twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=            # e.g. whatsapp:+14155238886 (sandbox) or your number

# ---- Store identity (used in messages) ----
NEXT_PUBLIC_STORE_NAME=Aggarwal Jewellers

# ---- Later phases (NOT needed for the demo) ----
# DELHIVERY_API_TOKEN=
# GA4_MEASUREMENT_ID=
# GA4_API_SECRET=
