# ---- Supabase (required for app; NOT required for unit tests) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Owner console auth (SECURITY-CRITICAL — set BOTH in production) ----
# This repo is public. The admin session cookie is a SHA-256 derived from these two secrets,
# so as long as at least one is set to a private value, the owner session CANNOT be forged
# from the source code. Leaving both unset = insecure. Rotating either logs everyone out.
OWNER_PASSCODE=            # the passcode the owner types to sign in — CHANGE from the demo default
ADMIN_SESSION_TOKEN=       # any long random string (e.g. `openssl rand -hex 32`)
OWNER_OTP=                 # numeric OTP guarding sensitive purchase actions

# ---- Demo safety ----
# The Phase-1 demo path makes NO live AI/3rd-party calls. Keys below are optional and
# only used by offline scripts (scripts/generate-content.ts) or later phases.

# ---- Optional: AI providers (offline content pre-generation only) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_BUDGET_PAISE=500000

# ---- Later phases (NOT needed for the demo) ----
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# DELHIVERY_API_TOKEN=

# ---- DIVA AI providers (any one enables LLM escalation; all three give fallback) ----
# Task routing: reasoning->OpenAI first, large context->Gemini first, fast->Groq first.
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
